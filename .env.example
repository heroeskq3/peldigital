# ─── Base de datos del SISTEMA ────────────────────────────────────────────────
# Contiene: users, roles, permissions, reports, audit_logs, schema_migrations
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pel_electoral
DB_USER=pel_user
DB_PASS=CAMBIAR_PASSWORD_SEGURO

# ─── Base de datos de DATOS ELECTORALES ───────────────────────────────────────
# Contiene: voters, provinces, cantons, districts, election_results, summaries…
# Si DW_HOST / DW_USER / DW_PASS están vacíos hereda los valores de DB_*
DW_HOST=127.0.0.1
DW_PORT=3306
DW_NAME=peldigital_data
DW_USER=pel_user
DW_PASS=CAMBIAR_PASSWORD_SEGURO

# ─── Entorno ──────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development

# ─── Sesión ──────────────────────────────────────────────────────────────────
# Cambiar en producción por un string aleatorio largo: openssl rand -hex 32
SESSION_NAME=PEL_SESSION
